{"version": 2, "rewrites": [
    {"source": "/yousuck.lua", "destination": "/api/yousuck"},
    {"source": "/scripts.lua", "destination": "/api/scripts"},
    {"source": "/api/get-key(.*)", "destination": "/api/get-key"},
    {"source": "/api/(.*)", "destination": "/api/index.js"},
    {"source": "/((?!api).*)", "destination": "/dist/index.html"}
  ]}
