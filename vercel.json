{"version": 2, "rewrites": [
    {"source": "/yousuck.lua", "destination": "/api/yousuck"},
    {"source": "/scripts.lua", "destination": "/api/yousuck"},
    {"source": "/api/yousuck", "destination": "/api/yousuck.js"},
    {"source": "/api/scripts", "destination": "/api/scripts.js"},
    {"source": "/api/access", "destination": "/api/access.js"},
    {"source": "/api/access/(.*)", "destination": "/api/access.js"},
    {"source": "/api/(.*)", "destination": "/api/index.js"},
    {"source": "/scripts/(.*)", "destination": "/scripts/$1"},
    {"source": "/((?!api|.*\\.lua).*)", "destination": "/index.html"}
  ]}
