{"version": 2, "rewrites": [
    {"source": "/yousuck.lua", "destination": "/api/yousuck"},
    {"source": "/scripts.lua", "destination": "/api/scripts"},
    {"source": "/verify", "destination": "/api/access.js"},
    {"source": "/api/access", "destination": "/api/access.js"},
    {"source": "/api/access/(.*)", "destination": "/api/access.js"},
    {"source": "/api/(.*)", "destination": "/api/index.js"},
    {"source": "/((?!api).*)", "destination": "/index.html"}
  ]}
